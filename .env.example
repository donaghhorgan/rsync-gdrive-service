# rclone Bisync Environment Variables
# ====================================
# Copy this file to .env and edit the values to override defaults.
# The .env file is gitignored and won't be committed.
#
# Usage:
#   cp .env.example .env
#   nano .env  # Edit with your values
#   source .env
#   ./rclone-bisync-gdrive.sh
#
# For systemd service: add EnvironmentFile=/path/to/.env to the service file

# Local directory to sync (absolute path)
LOCAL=$HOME/Documents

# Google Drive remote and path (format: remote:path)
REMOTE=gdrive:Documents

# State file - tracks sync history between runs
# CRITICAL: Never delete this file or bisync will resync everything
STATE_FILE=$HOME/.local/share/rclone-bisync-gdrive/state.json

# Backup directories - deleted files go here first
# At least one must be set
BACKUP_DIR_LOCAL=$HOME/.local/share/rclone-bisync-gdrive/backup
BACKUP_DIR_REMOTE=gdrive:Backup

# Log file for sync operations
LOG_FILE=$HOME/.cache/rclone-bisync-gdrive/log

# Lock file to prevent overlapping runs
LOCK_FILE=/tmp/rclone-bisync-gdrive.lock

# Conflict resolution: newest, oldest, path1, path2
# - newest: keep file with latest modification time (recommended)
# - oldest: keep file with earliest modification time
# - path1: always prefer local version
# - path2: always prefer remote version
CONFLICT_RESOLVE=newest

# Maximum number of files allowed to be deleted in one run
# Safety feature: aborts if more than this count would be deleted
MAX_DELETE_COUNT=10

# Suffix for conflict files (supports {DateOnly}, {Time}, etc.)
CONFLICT_SUFFIX=-{DateTime}-conflict
